# Docker Compose 专用环境变量模板
# 用法：cp backend/.env.docker.example .env
# 挂载到容器 /app/.env（cwd=/app）

# 服务器配置
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=production

# 数据路径（相对容器 cwd=/app；对应宿主机 ./data 挂载到 /app/backend/data）
NOVA_TASK_DB=backend/data/nova-tasks.sqlite
NOVA_IMAGE_DIR=backend/data/nova-images

# 最大并发图片数
NOVA_TASK_CONCURRENCY=50

# ============================================
# 队列与限流配置（运行时读取，修改 .env 后通常无需重启）
# ============================================

NOVA_MAX_QUEUE_SIZE=200
NOVA_RATE_LIMIT_WINDOW_MS=60000
NOVA_RATE_LIMIT_MAX_REQUESTS_PER_IP=10
NOVA_RATE_LIMIT_MAX_REQUESTS_PER_API_KEY=10
NOVA_MAX_PENDING_TASKS_PER_IP=20
NOVA_MAX_PENDING_TASKS_PER_API_KEY=20
NOVA_RATE_LIMIT_RETRY_AFTER_SECONDS=60

# ============================================
# 提示词广场配置（运行时读取，修改 .env 后通常无需重启）
# ============================================

# 1=常驻 2=私密（点七下标题） 3=关闭
PROMPT_GALLERY_MODE=1
PROMPT_GALLERY_PASSWORD=8848
